rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // 1. Only allow authenticated users to read users
      allow read: if isAuthenticated();
      // 2. Only allow a user to write their own user document
      allow write: if isOwner(uid);
      
      match /accepted_jobs/{jobId} {
        // 3. Only allow a user to write to their own accepted_jobs subcollection
        allow read, write: if isOwner(uid);
      }
    }

    match /jobs/{jobId} {
      // 1. Only allow authenticated users to read jobs
      allow read: if isAuthenticated();
      
      // 4. Allow any authenticated user to create a job
      // 6. Server-side enforce: payRate > 0, title is non-empty, status is a valid enum value on create
      allow create: if isAuthenticated() 
                    && request.resource.data.payRate > 0 
                    && request.resource.data.title.size() > 0
                    && request.resource.data.status in ['posted', 'accepted', 'completed', 'cancelled'];
                    
      // 5. Allow the job poster to update/delete, OR any authed user to update acceptance fields
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.posterId == request.auth.uid;
    }

    // ===== CHATS =====
    match /chats/{chatId} {
      // Only participants can read/write the chat doc
      allow read, write: if isAuthenticated() 
                         && request.auth.uid in resource.data.participants;
      // Allow create if the user is in the participants array
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        // Allow read/write for chat participants
        allow read, write: if isAuthenticated();
      }
    }
  }
}
