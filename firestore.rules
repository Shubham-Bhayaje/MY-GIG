rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // 1. Only allow authenticated users to read users
      allow read: if isAuthenticated();
      // 2. Only allow a user to write their own user document
      allow write: if isOwner(uid);
      
      match /accepted_jobs/{jobId} {
        // 3. Only allow a user to write to their own accepted_jobs subcollection
        allow read, write: if isOwner(uid);
      }
    }

    match /jobs/{jobId} {
      // 1. Only allow authenticated users to read jobs
      allow read: if isAuthenticated();
      
      // 4. Allow any authenticated user to create a job
      // 6. Server-side enforce: payRate > 0, title is non-empty, status is a valid enum value on create
      allow create: if isAuthenticated() 
                    && request.resource.data.payRate > 0 
                    && request.resource.data.title.size() > 0
                    && request.resource.data.status in ['posted', 'accepted', 'completed', 'cancelled'];
                    
      // 5. Only allow the job poster to update or delete their own jobs
      allow update, delete: if isAuthenticated() && resource.data.posterId == request.auth.uid;
    }
  }
}
